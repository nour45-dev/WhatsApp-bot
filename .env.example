# ============================================
# إعدادات مشتركة بين النسختين (QR و Meta API)
# ============================================

# رابط الشيت (خليه public / Anyone with the link can view)
GOOGLE_SHEET_ID=1243OxyD-OZ00OoY-hK5e0Mi3kkfSYtirjRbSJUQuExk

# لو الشيت فيه أكتر من صفحة (Sheet2, Sheet3..) وعايز صفحة معينة
GOOGLE_SHEET_GID=

# اسم ورقم الشخص المسؤول اللي البوت يحول عليه لو معرفش يرد
ADMIN_NAME=م/ وفاء ناصر
ADMIN_PHONE=01040581954

# اسم المركز (يستخدم في رسالة الترحيب)
BUSINESS_NAME=مركز الارائج التعليمي

# كل قد إيه (بالدقايق) البوت يحدّث بيانات الجدول من الشيت
SHEET_REFRESH_MINUTES=5

# المنفذ اللي السيرفر بيشتغل عليه محليًا (Render/Railway بيحطوه تلقائيًا)
PORT=3000


# ============================================
# إعدادات نسخة Meta Cloud API الرسمية فقط
# (سيبها فاضية لو هتستخدم نسخة QR بس)
# ============================================

# كلمة سر تختارها انت بنفسك، هتحطها هنا وكمان في إعدادات Webhook على Meta for Developers
META_VERIFY_TOKEN=اختار_كلمة_سر_قوية_هنا

# الـ Access Token من Meta for Developers > WhatsApp > API Setup
# (فيه نوعين: مؤقت 24 ساعة للتجربة، ودائم عن طريق System User للاستخدام الحقيقي)
META_ACCESS_TOKEN=

# Phone Number ID من نفس صفحة API Setup (مش رقم الموبايل نفسه، ده ID رقمي)
META_PHONE_NUMBER_ID=


# ============================================
# اختياري: ذكاء اصطناعي احتياطي مجاني عبر OpenRouter (للنسختين)
# لو البوت العادي معرفش يرد، هيحاول يسأل موديل مجاني قبل ما يحول العميل للإدارة.
# سيبه فاضي لو مش عايز الميزة دي (البوت هيشتغل عادي بالقواعد بس من غيرها).
# احصل على مفتاح مجاني من https://openrouter.ai (تسجيل بإيميل، من غير فيزا)
# ============================================
OPENROUTER_API_KEY=
